# Server-side only — never exposed to the browser.
# Get a key at https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin credentials (pick ONE):
# Local dev — absolute path to a service-account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# Amplify/hosted — base64 of the service-account JSON
# (generate with: base64 -i serviceAccountKey.json | tr -d '\n'):
# FIREBASE_SERVICE_ACCOUNT_BASE64=...

# Firebase client SDK config — these are meant to be public (they identify
# the project, not authenticate as it) and get inlined into the browser
# bundle at build time. Copy from Firebase Console → Project settings → your
# web app, or from another app in the same Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
